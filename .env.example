# Copy this file to .env and fill in values before deploying

# Set to False in production
DEBUG=False

# Generate a strong secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed hostnames (no wildcards in production)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
